<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>60.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Polymorphic Lookup (Flow)</masterLabel>
    <description>Allows searching across multiple objects in Flow screens.</description>
    <targets>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="label" label="Field Label" type="String" default="Related To" role="inputOnly"/>
            <property name="objectApiNames" label="Object API Names (CSV)" type="String" description="Comma-separated list (e.g., Account,Contact,Case)" role="inputOnly"/>
            <property name="iconNames" label="Icon Names (CSV)" type="String" description="Comma-separated list corresponding to objects (e.g., standard:account,standard:contact)" role="inputOnly"/>
            <property name="subtitleFields" label="Subtitle Fields (CSV)" type="String" description="Comma-separated list of fields to show under the name (e.g., BillingCity,Email)" role="inputOnly"/>
            <property name="required" label="Required" type="Boolean" default="false" role="inputOnly"/>

            <property name="selectedRecordId" label="Output: Selected Record ID" type="String" role="outputOnly"/>
            <property name="selectedObjectType" label="Output: Selected Object API Name" type="String" role="outputOnly"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
